//FOR LOOP

#include <stdio.h>

int main()
{
    int i;

    for(i=1; i <= 10; i++)
    {
        printf("%d ", i);
    }

    return 0;
}

//WHILE LOOP

#include <stdio.h>

int main()
{
    int i = 1;

    while(i <= 10)
    {
        printf("%d ", i);
        i++;
    }

